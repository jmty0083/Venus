<Window x:Class="PdfToMarkdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF → Markdown Converter"
        Width="760" Height="620"
        MinWidth="580" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="#F8F9FA">

    <Window.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="18"/>
            <Setter Property="Margin"       Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.07" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#DC2626" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#991B1B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#F3F4F6" CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#B91C1C" Padding="22,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📄" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PDF → Markdown Converter"
                               FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Convert PDF pages to Markdown with images preserved"
                               FontSize="11" Foreground="#FECACA" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="22,18,22,8"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Step 1: Open PDF -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepLabel}" Text="1. Open PDF File"/>
                        <Border x:Name="DropZone"
                                BorderBrush="#FECACA" BorderThickness="2"
                                CornerRadius="8" Background="#FFF5F5"
                                MinHeight="88" Cursor="Hand"
                                MouseLeftButtonDown="DropZone_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background"  Value="#FEE2E2"/>
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,14">
                                <TextBlock Text="📄" FontSize="30" HorizontalAlignment="Center"/>
                                <TextBlock Text="Drag &amp; drop a PDF file here"
                                           FontSize="13" Foreground="#6B7280"
                                           HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                <TextBlock Text="or click to browse"
                                           FontSize="11" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="TxtFilePath" Text="No file selected"
                                   FontSize="11" Foreground="#9CA3AF" Margin="0,8,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- Step 2: Page selection -->
                <Border x:Name="CardPages" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Style="{StaticResource StepLabel}"
                                       Text="2. Select Pages to Convert"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="All" Style="{StaticResource BtnSecondary}"
                                        Padding="10,5" Margin="0,0,6,0"
                                        Click="BtnSelectAll_Click"/>
                                <Button Content="None" Style="{StaticResource BtnSecondary}"
                                        Padding="10,5"
                                        Click="BtnSelectNone_Click"/>
                            </StackPanel>
                        </Grid>

                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                            <ListBox x:Name="LstPages"
                                     MaxHeight="220"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"          Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background"       Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,6" Background="Transparent">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Checked="PageCheck_Changed"
                                                      Unchecked="PageCheck_Changed">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="12" Foreground="#374151"
                                                           Margin="4,0,0,0"/>
                                            </CheckBox>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <TextBlock x:Name="TxtPageSummary"
                                   FontSize="11" Foreground="#6B7280" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Step 3: Output folder -->
                <Border x:Name="CardOutput" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepLabel}" Text="3. Select Output Folder"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#E5E7EB" BorderThickness="1"
                                    CornerRadius="6" Padding="10,7">
                                <TextBlock x:Name="TxtOutputFolder"
                                           Text="Click Browse to choose a folder..."
                                           Foreground="#9CA3AF" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="2" Content="  Browse...  "
                                    Style="{StaticResource BtnSecondary}"
                                    Padding="10,7" Click="BtnBrowse_Click"/>
                        </Grid>

                        <!-- Per-page option -->
                        <CheckBox x:Name="ChkPerPage"
                                  Margin="0,12,0,0"
                                  Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Per Page Markdown"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" VerticalAlignment="Center"/>
                                <TextBlock Text="  — one .md file per page"
                                           FontSize="12" Foreground="#6B7280"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- Step 4: Convert -->
                <Border x:Name="CardConvert" Style="{StaticResource Card}" Visibility="Collapsed">
                    <StackPanel>
                        <Button x:Name="BtnConvert"
                                Content="Create Markdown"
                                Style="{StaticResource BtnPrimary}"
                                Padding="0,13" IsEnabled="False"
                                Click="BtnConvert_Click"/>
                        <ProgressBar x:Name="PBar"
                                     Height="5" Margin="0,14,0,0"
                                     Visibility="Collapsed"
                                     IsIndeterminate="False"
                                     Minimum="0" Maximum="100"
                                     Foreground="#DC2626" Background="#FEE2E2"/>
                        <TextBlock x:Name="TxtStatus"
                                   FontSize="12" Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F3F4F6"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="22,7">
            <TextBlock x:Name="TxtStatusBar"
                       Text="Ready — open a PDF file to begin."
                       FontSize="11" Foreground="#6B7280"/>
        </Border>
    </Grid>
</Window>
