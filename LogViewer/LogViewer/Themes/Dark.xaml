<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBg"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceBg"       Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceAltBg"    Color="#232323"/>
    <SolidColorBrush x:Key="InputBg"         Color="#2D2D2D"/>
    <SolidColorBrush x:Key="HoverBg"         Color="#2A2D2E"/>
    <SolidColorBrush x:Key="HighlightBg"     Color="#3E3E3E"/>

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="PrimaryFg"       Color="#D4D4D4"/>
    <SolidColorBrush x:Key="MutedFg"         Color="#888888"/>
    <SolidColorBrush x:Key="SubtleFg"        Color="#BBBBBB"/>
    <SolidColorBrush x:Key="DisabledFg"      Color="#555555"/>

    <!-- Borders / lines -->
    <SolidColorBrush x:Key="BorderColor"     Color="#3C3C3C"/>
    <SolidColorBrush x:Key="GridLineColor"   Color="#2D2D2D"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectionBg"     Color="#264F78"/>
    <SolidColorBrush x:Key="SelectionFg"     Color="#FFFFFF"/>

    <!-- Menu hover -->
    <SolidColorBrush x:Key="MenuHighlightBg" Color="#094771"/>
    <SolidColorBrush x:Key="MenuHighlightFg" Color="#FFFFFF"/>

</ResourceDictionary>
