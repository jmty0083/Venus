<Window x:Class="Menelaus.Tian.Venus.LogViewer.AiSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure AI"
        Height="245" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground"        Value="{DynamicResource SubtleFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderColor}"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="SelectionBrush"           Value="{DynamicResource SelectionBg}"/>
            <Setter Property="Padding"                  Value="5,4"/>
            <Setter Property="FontFamily"               Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"     Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"     Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderColor}"/>
            <Setter Property="CaretBrush"     Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBg}"/>
            <Setter Property="Padding"        Value="5,4"/>
            <Setter Property="FontFamily"     Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"       Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding"     Value="14,5"/>
            <Setter Property="MinWidth"    Value="72"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="TabCtrl" Grid.Row="0" SelectedIndex="0"
                    Background="{DynamicResource WindowBg}"
                    BorderBrush="{DynamicResource BorderColor}">

            <!-- ── Tab 0: LLM Service ────────────────────────────────────── -->
            <TabItem Header="LLM Service">
                <Grid Margin="0,12,0,0" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label   Grid.Row="0" Grid.Column="0" Content="URL:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="LlmUrlBox"
                             ToolTip="LLM service endpoint URL"/>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Foreground="{DynamicResource SubtleFg}" FontSize="11">
                            <Run>Sends&#160;</Run><Run FontFamily="Consolas,Courier New">POST {"data":"&lt;prompt&gt;"}</Run>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource SubtleFg}" FontSize="11">
                            <Run>Expects&#160;</Run><Run FontFamily="Consolas,Courier New">{"pattern":"&lt;.NET named-group regex&gt;"}</Run>
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource SubtleFg}" FontSize="11" TextWrapping="Wrap">
                            <Run>The group&#160;</Run><Run FontFamily="Consolas,Courier New">(?&lt;text&gt;...)</Run><Run>&#160;must capture the main log message.</Run>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ── Tab 1: Azure OpenAI Key ───────────────────────────────── -->
            <TabItem Header="Azure OpenAI Key">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label   Grid.Row="0" Grid.Column="0" Content="Endpoint:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="EndpointBox"
                             ToolTip="OpenAI-compatible endpoint URL (e.g. https://api.openai.com/v1)"/>

                    <Label       Grid.Row="2" Grid.Column="0" Content="API Key:"/>
                    <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="ApiKeyBox"
                                 ToolTip="Your API key"/>

                    <Label   Grid.Row="4" Grid.Column="0" Content="Model:"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="ModelBox"
                             ToolTip="Model name (e.g. gpt-4o, gpt-4o-mini)"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Script-based plugin ───────────────────────────── -->
            <TabItem Header="Script-based plugin" Visibility="Collapsed">
                <Grid Margin="0,12,0,0" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label   Grid.Column="0" Content="Command:"/>
                    <TextBox Grid.Column="1" x:Name="CommandBox"
                             ToolTip="Shell command to invoke (receives log text via stdin, returns result via stdout)"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Separator -->
        <Separator Grid.Row="1" VerticalAlignment="Center"/>

        <!-- Buttons -->
        <Grid Grid.Row="2">
            <Button Content="Save"   HorizontalAlignment="Left"  Click="Save_Click"   IsDefault="True"/>
            <Button Content="Cancel" HorizontalAlignment="Right" Click="Cancel_Click" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
