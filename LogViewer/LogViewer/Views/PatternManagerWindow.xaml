<Window x:Class="Menelaus.Tian.Venus.LogViewer.PatternManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Patterns" Height="520" Width="760"
        Background="{DynamicResource WindowBg}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background"    Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"    Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderColor}"/>
            <Setter Property="CaretBrush"    Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBg}"/>
            <Setter Property="Padding"       Value="5,4"/>
            <Setter Property="FontFamily"    Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"      Value="12"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background"  Value="{DynamicResource SurfaceBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource PrimaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding"     Value="12,5"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="MinWidth"    Value="72"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HighlightBg}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Label}">
            <Setter Property="Foreground"       Value="{DynamicResource SubtleFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="0,0,8,0"/>
        </Style>
        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>         <!-- Pattern list -->
            <RowDefinition Height="Auto"/>      <!-- separator -->
            <RowDefinition Height="Auto"/>      <!-- edit label -->
            <RowDefinition Height="Auto"/>      <!-- name field -->
            <RowDefinition Height="80"/>        <!-- pattern field -->
            <RowDefinition Height="Auto"/>      <!-- text column -->
            <RowDefinition Height="Auto"/>      <!-- separator -->
            <RowDefinition Height="Auto"/>      <!-- button bar -->
        </Grid.RowDefinitions>

        <!-- Pattern list -->
        <DataGrid x:Name="PatternGrid"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource GridLineColor}"
                  HeadersVisibility="Column"
                  AlternationCount="2"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource BorderColor}"
                  Background="{DynamicResource WindowBg}"
                  RowBackground="{DynamicResource WindowBg}"
                  Foreground="{DynamicResource PrimaryFg}"
                  FontFamily="Consolas, Courier New, monospace"
                  FontSize="12"
                  ColumnHeaderHeight="26"
                  RowHeight="22"
                  Margin="0,0,0,8"
                  SelectionChanged="PatternGrid_SelectionChanged"/>

        <Separator Grid.Row="1" Margin="0,0,0,8"/>

        <!-- Edit area header -->
        <TextBlock Grid.Row="2" x:Name="EditLabel"
                   Text="New Pattern"
                   Foreground="{DynamicResource MutedFg}"
                   FontSize="11"
                   Margin="0,0,0,6"/>

        <!-- Name field -->
        <Grid Grid.Row="3" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Name:"/>
            <TextBox Grid.Column="1" x:Name="NameBox"/>
        </Grid>

        <!-- Pattern field -->
        <Grid Grid.Row="4" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Pattern:" VerticalAlignment="Top" Margin="0,4,8,0"/>
            <TextBox Grid.Column="1" x:Name="PatternBox"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="PatternBox_TextChanged"/>
        </Grid>

        <!-- Text column selector -->
        <Grid Grid.Row="5" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Text Col:"
                   ToolTip="Column that receives non-matching lines (e.g. stack traces)"/>
            <ComboBox Grid.Column="1" x:Name="TextColumnBox"
                      Background="{DynamicResource InputBg}"
                      Foreground="{DynamicResource PrimaryFg}"
                      BorderBrush="{DynamicResource BorderColor}"
                      ToolTip="Continuation lines (stack traces, wrapped text) are placed in this column. Defaults to the last column if not set."/>
        </Grid>

        <Separator Grid.Row="6" Margin="0,10,0,8"/>

        <!-- Button bar -->
        <Grid Grid.Row="7">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="New"            Click="New_Click"        Margin="0,0,6,0"/>
                <Button Content="Save"           Click="Save_Click"       Margin="0,0,6,0"/>
                <Button Content="Delete"         Click="Delete_Click"     Margin="0,0,6,0" x:Name="DeleteBtn"/>
                <Button Content="Set as Current" Click="SetCurrent_Click" x:Name="SetCurrentBtn"/>
            </StackPanel>
            <TextBlock x:Name="SaveStatus"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SaveConfirmFg}"
                       FontSize="12"/>
            <Button Content="Close" HorizontalAlignment="Right" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
